{
  "name": "podfast",
  "version": "0.1.0",
  "author": "PodFast Team",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:spotlight": "npx @spotlightjs/sidecar",
    "dev:next": "next dev",
    "dev": "run-p dev:*",
    "build:next": "next build",
    "build": "run-p build:* --race",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "clean": "rimraf .next out coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:types": "tsc --noEmit --pretty",
    "check:deps": "knip",
    "check:i18n": "i18n-check -l src/locales -s en -u src -f next-intl",
    "commit": "commit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "vitest run --config .storybook/vitest.config.mts",
    "build-storybook": "storybook build",
    "lighthouse": "unlighthouse-ci --site localhost:3000",
    "test:lighthouse": "run-p start lighthouse --race"
  },
  "dependencies": {
    "@arcjet/next": "^1.0.0-beta.8",
    "@commitlint/types": "^19.8.1",
    "@hookform/resolvers": "^5.2.2",
    "@logtape/logtape": "^1.1.2",
    "@sentry/nextjs": "^9.46.0",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.78.0",
    "@t3-oss/env-nextjs": "^0.13.8",
    "drizzle-orm": "^0.44.7",
    "import-in-the-middle": "^1.15.0",
    "mammoth": "^1.11.0",
    "next": "^15.5.6",
    "next-intl": "^4.4.0",
    "pdf-parse": "^1.1.4",
    "pg": "^8.16.3",
    "posthog-js": "^1.283.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.66.0",
    "require-in-the-middle": "^7.5.2",
    "vite": "^7.1.12",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.19.0",
    "@chromatic-com/playwright": "^0.12.7",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/prompt-cli": "^19.8.1",
    "@eslint-react/eslint-plugin": "^1.53.1",
    "@faker-js/faker": "^9.9.0",
    "@lingual/i18n-check": "^0.8.12",
    "@next/bundle-analyzer": "^15.5.6",
    "@next/eslint-plugin-next": "^15.3.5",
    "@playwright/test": "^1.56.1",
    "@spotlightjs/sidecar": "^1.12.0",
    "@spotlightjs/spotlight": "^3.0.2",
    "@storybook/addon-a11y": "^9.1.16",
    "@storybook/addon-docs": "^9.1.16",
    "@storybook/addon-vitest": "^9.1.16",
    "@storybook/nextjs-vite": "^9.1.16",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/node": "^24.9.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "checkly": "^6.8.2",
    "code-inspector-plugin": "^1.2.10",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.39.0",
    "eslint-plugin-format": "^1.0.2",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.3.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^9.1.16",
    "knip": "^5.66.4",
    "lefthook": "^1.13.6",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-load-config": "^6.0.1",
    "rimraf": "^6.1.0",
    "semantic-release": "^24.2.9",
    "storybook": "^9.0.16",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.8.3",
    "unlighthouse": "^0.17.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "vitest-browser-react": "^1.0.1"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/github"
    ]
  }
}
